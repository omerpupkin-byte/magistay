# ─── Magistay Backend — Environment Variables ─────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Anthropic (Claude AI) ────────────────────────────────────────
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Booking.com Affiliate API ────────────────────────────────────
# Apply at: https://developers.booking.com
# Leave empty while using mock data — the server detects this automatically
BOOKING_API_KEY=
BOOKING_API_SECRET=

# ── Expedia Rapid API ────────────────────────────────────────────
# Sign up at: https://developers.expediagroup.com
EXPEDIA_API_KEY=
EXPEDIA_API_SECRET=

# ── Google Maps (Geocoding) ──────────────────────────────────────
# Enable at: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=

# ── Frontend URL (CORS) ──────────────────────────────────────────
# In production: https://magistay.com
# In development: file:// or http://localhost:5173
FRONTEND_URL=*
