# ─── Magistay Backend — Environment Variables ─────────────────
# Copy this file to .env and fill in values.
# Add these to Railway Variables in production.
# NEVER commit .env to git.

# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Anthropic (Claude AI) ── ALREADY WORKING ────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_key_here

# ── Google Maps Geocoding ── ACTIVATE FOR RADIUS SEARCH ─────────
# console.cloud.google.com → Enable Geocoding API → Create Key
# Free: $200 credit/month (~40,000 requests)
GOOGLE_MAPS_API_KEY=

# ── Amadeus Hotel API ── INSTANT ACCESS ─────────────────────────
# developers.amadeus.com → Create account → New App → Get keys
# 150,000+ hotels worldwide. Free test quota. Instant access.
# This is the FASTEST way to get real hotel data.
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ── Expedia Rapid API ── WAITING FOR APPROVAL ────────────────────
# developers.expediagroup.com → Sign up → Get key immediately
# Covers: Expedia, Hotels.com
# Commission: 2-6% per booking
EXPEDIA_API_KEY=
EXPEDIA_API_SECRET=
EXPEDIA_AFFILIATE_ID=

# ── Booking.com ── WAITING FOR CJ APPROVAL ──────────────────────
# Step 1: CJ Affiliate approval (you already applied)
# Step 2: Get affiliate ID from CJ link builder
# Step 3: Apply for Demand API at developers.booking.com
BOOKING_AFFILIATE_ID=
BOOKING_API_KEY=
BOOKING_API_SECRET=

# ── Agoda ── APPLY AT partners.agoda.com ────────────────────────
AGODA_AFFILIATE_ID=

# ── Frontend URL (CORS) ──────────────────────────────────────────
FRONTEND_URL=https://magistay.com
